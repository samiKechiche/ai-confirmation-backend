{
  "name": "ai-confirmation-backend",
  "version": "1.0.0",
  "description": "Backend for the AI Order Confirmation internship project.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "npx prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "studio": "npx prisma studio",
    "docs:json": "node -e \"console.log(JSON.stringify(require('./src/config/swagger'), null, 2))\" > openapi.json",
    "migrate:test:reset": "DATABASE_URL=\"postgresql://ai_confirmation_user:password@localhost:5432/aiconfirmation_test?schema=public\" npx prisma migrate reset",

"test": "jest --runInBand"
  },
  "keywords": [
    "order-confirmation",
    "rest-api",
    "express",
    "prisma",
    "internship"
  ],
  "author": "Sami Kechiche",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.2.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
"devDependencies": {
    "jest": "^30.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/tests/globalSetup.js",
    "setupFiles": ["<rootDir>/tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js"]
  }

  
}
